# ─── Rust / Cargo ────────────────────────────────────────────────────────────
/target/
**/*.rs.bk
Cargo.lock          # En librerías se ignora; en binarios se versiona.
                    # Como este repo tiene ambos, lo dejamos fuera del VCS
                    # y cada crate decide. Ajusta si prefieres commit del lock.

# ─── Artefactos de compilación ───────────────────────────────────────────────
*.exe
*.dll
*.so
*.dylib
*.pdb
*.ilk
*.exp
*.lib              # Libs de importación generadas por MSVC (no las de Rust)

# ─── Checkpoints y archivos temporales del motor ─────────────────────────────
*.partial           # Archivos de copia incompleta generados por FileCopier
*.checkpoint        # Archivos de estado de checkpointing
*.fcp               # Extensión alternativa de checkpoint

# ─── IDEs y editores ─────────────────────────────────────────────────────────
.idea/
.vscode/
*.suo
*.user
*.user.*
.vs/
*.VC.db
*.VC.opendb

# ─── Sistema operativo ───────────────────────────────────────────────────────
Thumbs.db
.DS_Store
desktop.ini

# ─── Tauri (Fase 2) ──────────────────────────────────────────────────────────
app-gui/node_modules/
app-gui/dist/
app-gui/.next/
app-gui/src-tauri/target/
app-gui/src-tauri/WixTools/

# ─── Logs y telemetría ───────────────────────────────────────────────────────
*.log
logs/

# ─── Benchmarks y flamegraphs ────────────────────────────────────────────────
flamegraph.svg
perf.data
perf.data.old
criterion/